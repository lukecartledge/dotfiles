# Local/private git config
# Copy this file to ~/.gitconfig.local and update with your details
#
# This file is gitignored and should contain machine-specific settings
# like your identity. Signing is handled by the shared gitconfig via
# 1Password's op-ssh-sign.

[user]
	name = AUTHORNAME
	email = AUTHOREMAIL

[credential]
	helper = GIT_CREDENTIAL_HELPER
