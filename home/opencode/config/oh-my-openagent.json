    "multimodal-looker": {
      "model": "github-copilot/claude-sonnet-5"
    },
    "prometheus": {
      "model": "github-copilot/claude-opus-4.8",
      "variant": "high"
    },
    "metis": {
      "model": "github-copilot/claude-opus-4.8",
      "variant": "high"
