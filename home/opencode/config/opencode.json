{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["~/.config/opencode/AGENTS.md"],
  "plugin": ["oh-my-opencode@latest", "./plugins", "superpowers@git+https://github.com/obra/superpowers.git"],
  "autoupdate": true,
  "permission": {
    "read": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "todowrite": "allow",
    "todoread": "allow",
    "task": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "bash": {
      "git *": "allow",
      "gh *": "allow",
      "npm *": "allow",
      "yarn *": "allow",
      "node *": "allow",
      "npx *": "allow",
      "cat *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "which *": "allow",
      "echo *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "sort *": "allow",
      "grep *": "allow",
      "rg *": "allow",
      "jq *": "allow",
      "pwd": "allow",
      "env": "allow",
      "rm *": "ask",
      "mv *": "ask",
      "chmod *": "ask",
      "chown *": "ask",
      "sudo *": "deny",
      "curl *": "ask",
      "*": "ask"
    },
    "skill": {
      "*": "allow"
    }
  },
  "command": {
    "tdd": {
      "description": "Enforce TDD workflow with 80%+ coverage",
      "template": "{file:commands/tdd.md}\n\n$ARGUMENTS"
    },
    "verify": {
      "description": "Run verification loop to validate implementation",
      "template": "{file:commands/verify.md}\n\n$ARGUMENTS"
    },
    "save-session": {
      "description": "Save current session to Obsidian vault",
      "template": "{file:commands/save-session.md}\n\n$ARGUMENTS"
    },
    "save-prompt": {
      "description": "Save a reusable prompt to Obsidian vault",
      "template": "{file:commands/save-prompt.md}\n\n$ARGUMENTS"
    },
    "new-skill": {
      "description": "Scaffold a new skill in the Obsidian vault",
      "template": "{file:commands/new-skill.md}\n\n$ARGUMENTS"
    },
    "new-project": {
      "description": "Create a new project in the Obsidian vault with optional per-repo OpenCode config",
      "template": "{file:commands/new-project.md}\n\n$ARGUMENTS"
    }
  },
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "contentful": {
      "type": "local",
      "command": ["npx", "-y", "@contentful/mcp-server"],
      "environment": {
        "CONTENTFUL_MANAGEMENT_ACCESS_TOKEN": "{env:CONTENTFUL_MANAGEMENT_ACCESS_TOKEN}",
        "SPACE_ID": "{env:CONTENTFUL_SPACE_ID}",
        "ENVIRONMENT_ID": "master"
      },
      "enabled": false
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "newrelic": {
      "type": "remote",
      "url": "https://mcp.newrelic.com/mcp/",
      "headers": {
        "api-key": "{env:NEWRELIC_API_KEY}"
      },
      "oauth": false
    },
    "shopify": {
      "type": "local",
      "command": ["npx", "-y", "@shopify/dev-mcp@latest"]
    }
  }
}
