{
  "_comment": "Template for Claude Desktop config. Live file is ~/Library/Application Support/Claude/claude_desktop_config.json and is managed locally (not committed). Reconstruct on new machines using _setup commands, then verify with jq empty.",
  "_transport_note": "Claude Desktop only supports stdio transports (local process launch). Remote HTTP servers (atlassian, github, newrelic) are NOT valid here and will show 'could not be loaded' on startup. Those servers are configured separately in ~/.claude.json (user scope) for Claude Code. For Cowork access to those services, use the claude.ai Connectors UI inside Cowork.",
  "_setup": [
    "DESKTOP_CONFIG=\"$HOME/Library/Application Support/Claude/claude_desktop_config.json\"",
    "cp \"$DESKTOP_CONFIG\" \"${DESKTOP_CONFIG}.bak\"",
    "# Add stdio-only servers (contentful, context-mode, obsidian):",
    "jq '.mcpServers += {\"contentful\":{\"command\":\"npx\",\"args\":[\"-y\",\"@contentful/mcp-server\"],\"env\":{\"CONTENTFUL_MANAGEMENT_TOKEN\":\"${CONTENTFUL_MANAGEMENT_TOKEN}\",\"CONTENTFUL_SPACE_ID\":\"${CONTENTFUL_SPACE_ID}\"}},\"context-mode\":{\"command\":\"context-mode\"},\"obsidian\":{\"command\":\"npx\",\"args\":[\"-y\",\"obsidian-mcp-seekstone\"],\"env\":{\"SEEKSTONE_VAULT\":\"/Users/lukecartledge/notes/brain\"}}}' \"$DESKTOP_CONFIG\" > /tmp/desktop_merged.json",
    "jq empty /tmp/desktop_merged.json && cp /tmp/desktop_merged.json \"$DESKTOP_CONFIG\"",
    "jq empty \"$DESKTOP_CONFIG\""
  ],
  "mcpServers": {
    "_note": "stdio only — remote HTTP servers (atlassian, github, newrelic) belong in ~/.claude.json not here",
    "garmin": {
      "command": "uvx",
      "args": [
        "--python",
        "3.12",
        "--from",
        "git+https://github.com/Taxuspt/garmin_mcp",
        "garmin-mcp"
      ]
    },
    "contentful": {
      "command": "npx",
      "args": [
        "-y",
        "@contentful/mcp-server"
      ],
      "env": {
        "CONTENTFUL_MANAGEMENT_TOKEN": "${CONTENTFUL_MANAGEMENT_TOKEN}",
        "CONTENTFUL_SPACE_ID": "${CONTENTFUL_SPACE_ID}"
      }
    },
    "context-mode": {
      "command": "context-mode"
    },
    "obsidian": {
      "command": "npx",
      "args": [
        "-y",
        "obsidian-mcp-seekstone"
      ],
      "env": {
        "SEEKSTONE_VAULT": "/Users/lukecartledge/notes/brain"
      }
    }
  },
  "coworkUserFilesPath": "/Users/lukecartledge/Documents/Claude",
  "preferences": {
    "localAgentModeTrustedFolders": [
      "/Users/lukecartledge/notes/personal",
      "/Users/lukecartledge/Documents"
    ],
    "allowAllBrowserActions": true,
    "coworkScheduledTasksEnabled": true,
    "coworkHipaaRestricted": false,
    "ccdScheduledTasksEnabled": true,
    "sidebarMode": "task",
    "bypassPermissionsGateByAccount": {
      "112ea4b0-3db7-430e-b89f-2bc93cd5d451": false
    },
    "coworkWebSearchEnabled": true,
    "coworkModelAutoFallbackByAccount": {
      "112ea4b0-3db7-430e-b89f-2bc93cd5d451": true
    },
    "keepAwakeEnabled": true,
    "chicagoEnabled": true,
    "remoteToolsDeviceName": "mighty-mini-home",
    "epitaxyPrefs": {
      "starred-local-code-sessions": [],
      "starred-cowork-spaces": [],
      "starred-session-groups": [],
      "dframe-local-slice": {
        "pinnedOrder": [],
        "customGroupAssignments": {},
        "customGroupOrder": {}
      },
      "desktop-frame.paneStore.v1": {
        "state": {
          "extraPanesByMode": {},
          "colWeightsByMode": {},
          "rowSplit": 0.5,
          "draftNonce": 0
        },
        "version": 4
      },
      "ccd-sessions-filter": {
        "state": {
          "selectedProjects": []
        },
        "version": 0
      }
    }
  }
}
