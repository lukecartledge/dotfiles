{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "github-copilot/claude-opus-4.8",
  "permissions": {
    "allow": [],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Read(**/.env)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*id_rsa*)",
      "Read(**/*id_ed25519*)",
      "Read(**/*credentials*)",
      "Read(**/*.secret)"
    ]
  },
  "enabledPlugins": {}
}
