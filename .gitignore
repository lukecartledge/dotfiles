# Local git configuration (contains user-specific settings)
git/gitconfig.local.symlink
home/git/gitconfig.local

# Homebrew lock file
Brewfile.lock.json

# Zed local settings (may contain API tokens)
home/zed/config/settings.local.json

# iTerm2 live preferences (managed via defaults write in install.bash)
home/iterm2/com.googlecode.iterm2.plist
home/iterm2/*.plist.lock

# Local/machine-specific overrides
*.local
*.local.json
!*.local.example
!*.local.json.example

# Editor and OS files
.DS_Store
*.swp
*.swo
*~
.idea/
.vscode/

# Backup files created during linking
*.backup.*

# npm artifacts (from plugin installs)
node_modules/
package.json
package-lock.json
